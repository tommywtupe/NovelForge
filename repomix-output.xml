            <p class="text"><b>名称：</b>{{ outline.main_target.name || '未设置' }}</p>
            <p class="text"><b>概述：</b>{{ outline.main_target.overview || '暂无概述' }}</p>
          </div>
          <div v-if="Array.isArray(outline.branch_line) && outline.branch_line.length" class="section">
