          </div>
          <div v-if="Array.isArray(outline.character_snapshot) && outline.character_snapshot.length" class="section">
            <div class="sec-title">🧭 卷末快照</div>
            <ul class="list">
              <li v-for="(s, i) in outline.character_snapshot" :key="i">{{ s }}</li>
