      <el-collapse-item v-for="(sec, idx) in sections" :key="idx" :name="String(idx)">
        <template #title>
          <span class="sec-title">{{ sec.title }}</span>
          <span class="sec-desc" v-if="sec.description">{{ sec.description }}</span>
        </template>
        <ModelDrivenForm
          :schema="schema"
          v-model="proxy"
