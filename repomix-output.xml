): Promise<any[]> {
  const params = new URLSearchParams({ project_id: String(projectId) })
  if (targetLanguage) {
    params.set('target_language', targetLanguage)
  }
  return request.get<any[]>(`/glossary/list?${params.toString()}`)
}

