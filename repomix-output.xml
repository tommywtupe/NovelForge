					size="small"
					placeholder="选择术语表"
					class="glossary-select"
					clearable
					@change="handleGlossaryChange"
				>
					<el-option
						v-for="glossary in glossaryOptions"
						:key="glossary.id"
						:label="glossary.title"
						:value="glossary.id"
