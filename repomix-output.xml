@import './base.css';

:root {
  /* Primary Color - Element Plus Default */
  --primary-color: #409EFF;
  --primary-gradient: linear-gradient(135deg, #409EFF 0%, #53a8ff 100%);
  --secondary-color: #67C23A;

  --bg-color: #f8fafc;
  --bg-color-glass: rgba(255, 255, 255, 0.85);

  --text-primary: #1e293b;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;

  --border-color: #e2e8f0;
  --border-radius-sm: 6px;
  --border-radius-md: 10px;
  --border-radius-lg: 16px;

  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  --shadow-premium: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
}

body {
  margin: 0;
  padding: 0;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  /* Reset the flex centering from template */
  display: block;
}

#app {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
}

/* Glassmorphism Utilities */
.glass {
  background: var(--bg-color-glass);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.5);
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* Element Plus Overrides for Premium Feel */
.el-button--primary {
  background: var(--primary-color) !important;
  border-color: var(--primary-color) !important;
  color: white !important;
  font-weight: 500;
}

.el-button--primary:hover {
  filter: brightness(1.1);
}

.el-input__wrapper,
.el-textarea__inner {
  box-shadow: 0 0 0 1px var(--border-color) inset !important;
  transition: all 0.2s;
}

.el-input__wrapper.is-focus,
.el-textarea__inner:focus {
  box-shadow: 0 0 0 1px var(--primary-color) inset !important;
}

.el-tag {
  border-radius: 4px;
}
