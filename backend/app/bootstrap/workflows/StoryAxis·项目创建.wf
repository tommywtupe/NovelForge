#@node(description="创建繁体中文术语表")
glossary_zh_tw = Card.Create(
    project_id=trigger.project_id,
    card_type="StoryAxis·翻译术语表",
    title="StoryAxis·术语表·繁體中文",
    content={
        "name": "StoryAxis·术语表·繁體中文",
        "target_language": "繁體中文",
        "terms": []
    }
  )
#</node>


