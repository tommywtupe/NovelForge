# 工作流：StoryAxis·项目创建
# 功能：为 StoryAxis 项目初始化基础创作卡与翻译资产

#@node(description="触发器：监听 StoryAxis 项目创建事件")
trigger = Trigger.ProjectCreated(template="storyaxis")
#</node>


#@node()
tags = Card.Create(
    project_id=trigger.project_id,
    card_type="StoryAxis·作品标签",
    title="StoryAxis·作品标签"
  )
#</node>


#@node()
power = Card.Create(
    project_id=trigger.project_id,
    card_type="StoryAxis·金手指",
    title="StoryAxis·金手指"
  )
#</node>


